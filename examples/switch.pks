pollob start
    din = 3;

    switch on(din) {
        1:
            bolo pollob "Sombar";
            thamo;
        2:
            bolo pollob "Mongolbar";
            thamo;
        3:
            bolo pollob "Budhbar";
            thamo;
        default:
            bolo pollob "Janina kon din";
    }
pollob end
